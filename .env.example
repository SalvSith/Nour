# Frontend environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.

# URL of the emotion API endpoint.
# Option A (Supabase): https://<project-ref>.supabase.co/functions/v1/emotion
# Option B (local Node server): http://localhost:3001/emotion  ← default when unset
VITE_API_URL=

# WebSocket URL — only needed if you switch App.tsx to use wsClient.ts instead of apiClient.ts
# wss://<your-server>/
VITE_WS_URL=
